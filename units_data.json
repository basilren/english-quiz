      "sentences": [
        {"en": "First, they'll visit our classroom.", "zh": "首先, 他们将参观我们的教室。"},
        {"en": "Next, they'll visit the art room.", "zh": "然后, 他们将参观美术教室。"},
        {"en": "Then they'll go to the hall.", "zh": "接着, 他们将去礼堂。"},
        {"en": "After that, they'll go to the library.", "zh": "之后, 他们将去图书馆。"},
        {"en": "Finally, they'll meet the teachers in the meeting room.", "zh": "最后, 他们将在会议室和老师们见面。"},
        {"en": "Ms Guo welcomes the parents at the school gate.", "zh": "郭老师在学校门口欢迎家长们。"},
        {"en": "She tells them about the lessons.", "zh": "她向他们介绍课程。"},
        {"en": "The children show their parents some beautiful pictures.", "zh": "同学们向他们的家长们展示美丽的图画。"},
        {"en": "The children sing for their parents.", "zh": "孩子们给他们的家长们唱歌。"},
        {"en": "They look at the homework and projects on the board.", "zh": "他们看展板上的作业和课题。"}
      ]
    },
