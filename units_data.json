      "sentences": [
        {"en": "What do you do at the weekend?", "zh": "你周末做什么?"},
        {"en": "I always do my homework on Saturday morning.", "zh": "我总是在周六早上做作业。"},
        {"en": "I usually go swimming on Sunday.", "zh": "我通常周日去游泳。"},
        {"en": "I sometimes play football with my friends.", "zh": "我有时和朋友们踢足球。"},
        {"en": "She often reads books at home.", "zh": "她经常在家看书。"},
        {"en": "We never watch TV on school days.", "zh": "上学日我们从不看电视。"},
